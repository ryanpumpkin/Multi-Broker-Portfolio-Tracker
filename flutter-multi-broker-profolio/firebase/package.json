{
  "name": "mbp-tracker-firebase",
  "version": "0.1.0",
  "private": true,
  "description": "Firestore rules + emulator tests for the Multi-Broker Portfolio Tracker.",
  "scripts": {
    "test": "mocha --reporter spec --timeout 20000 tests/**/*.test.js",
    "test:emulator": "firebase emulators:exec --only firestore,auth --project mbp-tracker-test \"npm test\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "firebase": "^10.12.0",
    "mocha": "^10.4.0"
  }
}
