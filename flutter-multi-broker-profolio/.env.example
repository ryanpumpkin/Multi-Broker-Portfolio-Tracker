# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────
MBP_ENV=production                         # development | production
MBP_LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
MBP_AUTH_DISABLED=false                    # set true only for local dev/testing

# CORS: comma-separated origins (or * for dev)
MBP_CORS_ORIGINS=["*"]

# ── Firebase ─────────────────────────────────────────────────────────────────
MBP_FIREBASE_PROJECT_ID=your-firebase-project-id
# Path inside the container to a service-account JSON key (optional; if omitted
# the backend uses Application Default Credentials).
MBP_FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase_sa.json

# ── FX Rate Provider ─────────────────────────────────────────────────────────
MBP_FX_PROVIDER=exchangerate.host          # exchangerate.host | openexchangerates
MBP_FX_PROVIDER_API_KEY=

# ── KMS (server-key mode for background alert evaluation) ────────────────────
# `file` uses a local file-backed master key (suitable for local dev).
# For production use `gcp` or `aws` with a managed key.
MBP_KMS_PROVIDER=file
# Absolute path INSIDE the container. The Docker setup bind-mounts
# ./backend/.secrets to /home/mbp/.secrets so the key persists across rebuilds.
MBP_KMS_KEY_ID=/home/mbp/.secrets/mbp-master.key

# ── IBKR Gateway sidecar ─────────────────────────────────────────────────────
# These point at the ibkr-gateway container; defaults match docker-compose.yml.
MBP_IB_GATEWAY_HOST=ibkr-gateway
MBP_IB_GATEWAY_PORT=5000

# IBKR credentials — supplied to the ibkr-gateway container at runtime.
# See infra/README.md §IBKR Sidecar for setup instructions.
IBKR_USERNAME=
IBKR_PASSWORD=
IBKR_TRADING_MODE=paper                    # paper | live

# ── Futu OpenD sidecar ───────────────────────────────────────────────────────
# These point at the futu-opend container; defaults match docker-compose.yml.
MBP_FUTU_OPEND_HOST=futu-opend
MBP_FUTU_OPEND_PORT=11111

# Futu credentials — supplied to the futu-opend container at runtime.
# See infra/README.md §Futu Sidecar for setup instructions.
FUTU_OPEND_LOGIN_ACCOUNT=
FUTU_OPEND_LOGIN_PASSWORD_MD5=
FUTU_OPEND_TRADE_RSA_FILE=
