# Copy to .env for local dev.
MBP_ENV=development
MBP_LOG_LEVEL=INFO

# Firebase
MBP_FIREBASE_PROJECT_ID=
MBP_FIREBASE_CREDENTIALS_PATH=

# KMS (server-key mode for credential vault)
MBP_KMS_PROVIDER=none
MBP_KMS_KEY_ID=

# FX provider
MBP_FX_PROVIDER=exchangerate.host
MBP_FX_PROVIDER_API_KEY=

# Broker gateway sidecars
MBP_IB_GATEWAY_HOST=localhost
MBP_IB_GATEWAY_PORT=5000
MBP_FUTU_OPEND_HOST=localhost
MBP_FUTU_OPEND_PORT=11111

# CORS (JSON list)
MBP_CORS_ORIGINS=["*"]

# Set true to bypass auth in local dev / tests
MBP_AUTH_DISABLED=false
